@model ServiceCenter.Web.ViewModels.Account.LoginViewModel
@{ ViewData["Title"] = "Sign In"; Layout = "_Layout"; }

<div class="card shadow-sm" style="width: 380px;">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <i class="bi bi-tools fs-1 text-primary"></i>
            <h4 class="mt-2 fw-bold">Service Center</h4>
            <p class="text-muted small">Sign in to your account</p>
        </div>

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small fw-semibold"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label small fw-semibold"></label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label small"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
            </button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
