@model IEnumerable<ServiceCenter.Domain.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Users";
    var search = ViewData["Search"] as string;
    var activeOnly = (bool)(ViewData["ActiveOnly"] ?? true);
    var userRoles = ViewBag.UserRoles as Dictionary<string, string> ?? new();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Users</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>New User
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="search" value="@search" class="form-control form-control-sm"
                   placeholder="Search by name or email…" style="max-width:280px" />
            <div class="form-check ms-2 mb-0">
                <input class="form-check-input" type="checkbox" name="activeOnly" value="true"
                       id="activeOnly" @(activeOnly ? "checked" : "") />
                <label class="form-check-label small" for="activeOnly">Active only</label>
            </div>
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-search me-1"></i>Filter
            </button>
            @if (!string.IsNullOrWhiteSpace(search) || !activeOnly)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-muted text-center py-5">
            <i class="bi bi-people fs-1 d-block mb-2"></i>
            <span>No users found.</span>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-center">Status</th>
                        <th>Joined</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var role = userRoles.GetValueOrDefault(u.Id, "—");
                        <tr class="@(!u.IsActive ? "text-muted" : "")">
                            <td class="fw-semibold">@u.LastName @u.FirstName</td>
                            <td>@u.Email</td>
                            <td><span class="badge bg-secondary">@role</span></td>
                            <td class="text-center">
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@u.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (u.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <a asp-action="Delete" asp-route-id="@u.Id"
                                       class="btn btn-sm btn-outline-danger" title="Deactivate">
                                        <i class="bi bi-person-x"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">@Model.Count() user(s)</div>
    </div>
}
