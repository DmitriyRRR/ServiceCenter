<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Service Center</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="d-flex flex-column flex-shrink-0 p-3">
            <a href="/" class="sidebar-brand d-flex align-items-center mb-3 text-decoration-none">
                <i class="bi bi-tools me-2 fs-4"></i>
                <span class="fs-5 fw-semibold">ServiceCenter</span>
            </a>
            <hr />
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       href="/"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager") || User.IsInRole("Engineer"))
                {
                    <li class="nav-item"><span class="sidebar-section">Tickets</span></li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets" ? "active" : "")"
                           asp-controller="Tickets" asp-action="Index">
                            <i class="bi bi-ticket-detailed me-2"></i>All Tickets
                        </a>
                    </li>
                    @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
                    {
                        <li>
                            <a class="nav-link" asp-controller="Tickets" asp-action="Create">
                                <i class="bi bi-plus-circle me-2"></i>New Ticket
                            </a>
                        </li>
                    }
                }

                @if (User.IsInRole("Client"))
                {
                    <li class="nav-item"><span class="sidebar-section">My Devices</span></li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MyTickets" ? "active" : "")"
                           asp-controller="MyTickets" asp-action="Index">
                            <i class="bi bi-phone me-2"></i>My Repairs
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
                {
                    <li class="nav-item"><span class="sidebar-section">Clients</span></li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
                           asp-controller="Clients" asp-action="Index">
                            <i class="bi bi-people me-2"></i>Clients
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Devices" ? "active" : "")"
                           asp-controller="Devices" asp-action="Index">
                            <i class="bi bi-cpu me-2"></i>Devices
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Engineer") || User.IsInRole("ServiceManager"))
                {
                    <li class="nav-item"><span class="sidebar-section">Inventory</span></li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Parts" ? "active" : "")"
                           asp-controller="Parts" asp-action="Index">
                            <i class="bi bi-box-seam me-2"></i>Parts
                        </a>
                    </li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PartOrders" ? "active" : "")"
                           asp-controller="PartOrders" asp-action="Index">
                            <i class="bi bi-cart me-2"></i>Orders
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Engineer"))
                {
                    <li class="nav-item"><span class="sidebar-section">Configuration</span></li>
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkTypes" ? "active" : "")"
                           asp-controller="WorkTypes" asp-action="Index">
                            <i class="bi bi-wrench me-2"></i>Work Types
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                           asp-controller="Users" asp-action="Index">
                            <i class="bi bi-person-gear me-2"></i>Users
                        </a>
                    </li>
                }
            </ul>
            <hr />
            <div class="d-flex align-items-center sidebar-user">
                <i class="bi bi-person-circle me-2 fs-5"></i>
                <span class="small flex-grow-1 text-truncate">@User.Identity!.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="ms-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Page Content -->
        <div id="page-content" class="flex-grow-1 d-flex flex-column">
            <nav class="topbar navbar px-4">
                <button class="btn btn-sm btn-outline-secondary me-3" id="sidebarToggle" type="button">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <div class="flex-grow-1">
                    @if (ViewData["Breadcrumb"] is not null)
                    {
                        @Html.Raw(ViewData["Breadcrumb"])
                    }
                </div>
            </nav>

            <main class="p-4 flex-grow-1">
                @if (TempData["Success"] is not null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is not null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>

        <!-- Auto-logout: hidden form + warning modal -->
        <form id="idle-logout-form" asp-controller="Account" asp-action="Logout" method="post" class="d-none"></form>
        <div class="modal fade" id="idleWarningModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-labelledby="idleWarningLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title" id="idleWarningLabel">
                            <i class="bi bi-clock-history text-warning me-2"></i>Session Expiring
                        </h5>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">You have been inactive. You will be logged out in <strong id="idle-countdown">2:00</strong>.</p>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-primary" id="idle-stay-btn">
                            <i class="bi bi-arrow-repeat me-1"></i>Stay Logged In
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="auth-wrapper d-flex align-items-center justify-content-center min-vh-100">
        @RenderBody()
    </div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
@if (User.Identity?.IsAuthenticated == true)
{
    <script>
    (function () {
        var WARN_AFTER   = 28 * 60 * 1000;   // show warning at 28 min
        var LOGOUT_AFTER = 30 * 60 * 1000;   // hard logout at 30 min

        var modalEl      = document.getElementById('idleWarningModal');
        var countdownEl  = document.getElementById('idle-countdown');
        var logoutForm   = document.getElementById('idle-logout-form');
        var bsModal      = new bootstrap.Modal(modalEl);

        var warnTimer, logoutTimer, countdownInterval;

        function doLogout() {
            clearInterval(countdownInterval);
            logoutForm.submit();
        }

        function updateCountdown(s) {
            var m = Math.floor(s / 60);
            countdownEl.textContent = m + ':' + String(s % 60).padStart(2, '0');
        }

        function showWarning() {
            var remaining = 120;
            updateCountdown(remaining);
            bsModal.show();
            countdownInterval = setInterval(function () {
                remaining--;
                updateCountdown(remaining);
                if (remaining <= 0) doLogout();
            }, 1000);
        }

        function resetTimers() {
            clearTimeout(warnTimer);
            clearTimeout(logoutTimer);
            clearInterval(countdownInterval);
            bootstrap.Modal.getInstance(modalEl)?.hide();
            warnTimer    = setTimeout(showWarning, WARN_AFTER);
            logoutTimer  = setTimeout(doLogout,    LOGOUT_AFTER);
        }

        document.getElementById('idle-stay-btn').addEventListener('click', resetTimers);

        ['mousemove', 'keydown', 'mousedown', 'scroll', 'touchstart'].forEach(function (evt) {
            document.addEventListener(evt, resetTimers, { passive: true });
        });

        resetTimers(); // start on page load
    })();
    </script>
}
</body>
</html>
