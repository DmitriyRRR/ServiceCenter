@model ServiceCenter.Domain.Entities.Device
@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
    ViewData["Breadcrumb"] = $"<a href='/Devices' class='text-decoration-none'>Devices</a> / {Model.Brand} {Model.Model}";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">@Model.Brand @Model.Model</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
            <i class="bi bi-trash me-1"></i>Delete
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-cpu me-2"></i>Device Info
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Brand</dt>
                    <dd class="col-sm-8">@Model.Brand</dd>

                    <dt class="col-sm-4 text-muted">Model</dt>
                    <dd class="col-sm-8">@Model.Model</dd>

                    <dt class="col-sm-4 text-muted">Serial No.</dt>
                    <dd class="col-sm-8">@(Model.SerialNumber ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Added</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-person me-2"></i>Owner
            </div>
            <div class="card-body">
                <a asp-controller="Clients" asp-action="Details" asp-route-id="@Model.ClientId"
                   class="fw-semibold text-decoration-none fs-5">
                    @Model.Client.LastName @Model.Client.FirstName
                </a>
                <div class="text-muted small mt-1">@Model.Client.Phone</div>
                @if (Model.Client.Email != null)
                {
                    <div class="text-muted small">@Model.Client.Email</div>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="bi bi-journal-text me-2"></i>Description
                </div>
                <div class="card-body">
                    <p class="mb-0" style="white-space:pre-wrap">@Model.Description</p>
                </div>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-ticket-detailed me-2"></i>Tickets</span>
                <span class="badge bg-secondary">@Model.Tickets.Count</span>
            </div>
            @if (Model.Tickets.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var t in Model.Tickets)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id"
                               class="text-decoration-none">@t.TicketNumber</a>
                            <span class="badge bg-secondary">@t.Status</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted">No tickets for this device.</div>
            }
        </div>
    </div>
</div>
