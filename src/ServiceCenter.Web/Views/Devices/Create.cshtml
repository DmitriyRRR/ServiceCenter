@model ServiceCenter.Web.Models.DeviceFormViewModel
@{
    ViewData["Title"] = "New Device";
    ViewData["Breadcrumb"] = "<a href='/Devices' class='text-decoration-none'>Devices</a> / New Device";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">New Device</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="ClientId" class="form-label"></label>
                    <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select">
                        <option value="">— select client —</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Brand" class="form-label"></label>
                    <input asp-for="Brand" class="form-control" placeholder="e.g. Apple" />
                    <span asp-validation-for="Brand" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Model" class="form-label"></label>
                    <input asp-for="Model" class="form-control" placeholder="e.g. iPhone 15" />
                    <span asp-validation-for="Model" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="SerialNumber" class="form-label"></label>
                    <input asp-for="SerialNumber" class="form-control" />
                    <span asp-validation-for="SerialNumber" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
