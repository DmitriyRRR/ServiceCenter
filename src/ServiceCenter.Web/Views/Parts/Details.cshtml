@model ServiceCenter.Domain.Entities.Part
@using ServiceCenter.Domain.Enums
@{
    ViewData["Title"] = Model.Name;
    ViewData["Breadcrumb"] = $"<a href='/Parts' class='text-decoration-none'>Parts</a> / {Model.Name}";

    string StatusBadge(PartStatus s) => s switch
    {
        PartStatus.InStock    => "success",
        PartStatus.LowStock   => "warning text-dark",
        PartStatus.OutOfStock => "danger",
        PartStatus.Ordered    => "info text-dark",
        _                     => "secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-semibold mb-0">@Model.Name</h4>
        <span class="badge bg-@StatusBadge(Model.Status) mt-1">@Model.Status</span>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>
    }
    else
    {
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    }
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="bi bi-box-seam me-2"></i>Part Info</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">SKU</dt>
                    <dd class="col-sm-7">@(Model.SKU ?? "—")</dd>

                    <dt class="col-sm-5 text-muted">Unit Price</dt>
                    <dd class="col-sm-7 fw-semibold">@Model.UnitPrice.ToString("C")</dd>

                    <dt class="col-sm-5 text-muted">In Stock</dt>
                    <dd class="col-sm-7 @(Model.QuantityInStock <= Model.LowStockThreshold ? "text-warning fw-semibold" : "")">
                        @Model.QuantityInStock
                    </dd>

                    <dt class="col-sm-5 text-muted">Low Stock At</dt>
                    <dd class="col-sm-7">@Model.LowStockThreshold</dd>

                    <dt class="col-sm-5 text-muted">Added</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-5 text-muted">Updated</dt>
                    <dd class="col-sm-7">@Model.UpdatedAt.ToString("dd MMM yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-journal-text me-2"></i>Description</div>
                <div class="card-body">
                    <p class="mb-0" style="white-space:pre-wrap">@Model.Description</p>
                </div>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-ticket-detailed me-2"></i>Used in Tickets</span>
                <span class="badge bg-secondary">@Model.TicketParts.Count</span>
            </div>
            @if (Model.TicketParts.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ticket</th>
                                <th>Client</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tp in Model.TicketParts)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Tickets" asp-action="Details" asp-route-id="@tp.TicketId"
                                           class="text-decoration-none">@tp.Ticket.TicketNumber</a>
                                    </td>
                                    <td>@tp.Ticket.Client.LastName @tp.Ticket.Client.FirstName</td>
                                    <td class="text-center">@tp.Quantity</td>
                                    <td class="text-end">@tp.UnitPriceAtTime.ToString("C")</td>
                                    <td class="text-end">@tp.TotalPrice.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body text-muted">This part has not been used in any tickets.</div>
            }
        </div>
    </div>
</div>
