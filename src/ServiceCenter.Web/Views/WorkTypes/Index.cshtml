@model IEnumerable<ServiceCenter.Domain.Entities.WorkType>
@{
    ViewData["Title"] = "Work Types";
    var search = ViewData["Search"] as string;
    var activeOnly = (bool)(ViewData["ActiveOnly"] ?? true);
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Work Types</h4>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Work Type
        </a>
    }
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="search" value="@search" class="form-control form-control-sm"
                   placeholder="Search by name…" style="max-width:260px" />
            <div class="form-check ms-2 mb-0">
                <input class="form-check-input" type="checkbox" name="activeOnly" value="true"
                       id="activeOnly" @(activeOnly ? "checked" : "") />
                <label class="form-check-label small" for="activeOnly">Active only</label>
            </div>
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-search me-1"></i>Filter
            </button>
            @if (!string.IsNullOrWhiteSpace(search) || !activeOnly)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-muted text-center py-5">
            <i class="bi bi-wrench fs-1 d-block mb-2"></i>
            <span>No work types found.</span>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-end">Default Price</th>
                        <th class="text-center">Status</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model)
                    {
                        <tr class="@(!w.IsActive ? "text-muted" : "")">
                            <td class="fw-semibold">@w.Name</td>
                            <td class="text-muted small">@(w.Description ?? "—")</td>
                            <td class="text-end">@w.DefaultPrice.ToString("C")</td>
                            <td class="text-center">
                                @if (w.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@w.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@w.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">@Model.Count() work type(s)</div>
    </div>
}
