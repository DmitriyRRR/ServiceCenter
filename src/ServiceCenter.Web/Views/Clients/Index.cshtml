@model IEnumerable<ServiceCenter.Domain.Entities.Client>
@{
    ViewData["Title"] = "Clients";
    var search = ViewData["Search"] as string;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Clients</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>New Client
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@search" class="form-control form-control-sm"
                   placeholder="Search by name, phone or email…" style="max-width:320px" />
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-muted text-center py-5">
            <i class="bi bi-people fs-1 d-block mb-2"></i>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <span>No clients found for "<strong>@search</strong>".</span>
            }
            else
            {
                <span>No clients yet. <a asp-action="Create">Add the first one.</a></span>
            }
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Since</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="fw-semibold text-decoration-none">
                                    @c.LastName @c.FirstName
                                </a>
                            </td>
                            <td>@c.Phone</td>
                            <td>@(c.Email ?? "—")</td>
                            <td class="text-truncate" style="max-width:180px">@(c.Address ?? "—")</td>
                            <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">
            @Model.Count() client(s) found
        </div>
    </div>
}
