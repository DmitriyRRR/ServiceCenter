@model ServiceCenter.Domain.Entities.Client
@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}";
    ViewData["Breadcrumb"] = $"<a href='/Clients' class='text-decoration-none'>Clients</a> / {Model.FirstName} {Model.LastName}";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">@Model.FirstName @Model.LastName</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
            <i class="bi bi-trash me-1"></i>Delete
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-person me-2"></i>Contact Info
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@(Model.Email ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">@(Model.Address ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Since</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-journal-text me-2"></i>Notes
            </div>
            <div class="card-body">
                @if (string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <span class="text-muted">No notes.</span>
                }
                else
                {
                    <p class="mb-0" style="white-space:pre-wrap">@Model.Notes</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-cpu me-2"></i>Devices</span>
                <span class="badge bg-secondary">@Model.Devices.Count</span>
            </div>
            @if (Model.Devices.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var d in Model.Devices)
                    {
                        <li class="list-group-item">
                            <i class="bi bi-cpu me-2 text-muted"></i>@d.Brand @d.Model
                            <span class="text-muted small ms-2">S/N: @(d.SerialNumber ?? "—")</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted">No devices registered.</div>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-ticket-detailed me-2"></i>Tickets</span>
                <span class="badge bg-secondary">@Model.Tickets.Count</span>
            </div>
            @if (Model.Tickets.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var t in Model.Tickets)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id"
                               class="text-decoration-none">@t.TicketNumber</a>
                            <span class="badge bg-secondary">@t.Status</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted">No tickets yet.</div>
            }
        </div>
    </div>
</div>
