@model ServiceCenter.Web.Models.TicketFormViewModel
@using ServiceCenter.Domain.Enums
@{
    ViewData["Title"] = "Edit Ticket";
    ViewData["Breadcrumb"] = "<a href='/Tickets' class='text-decoration-none'>Tickets</a> / Edit";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Edit Ticket</h4>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card" style="max-width:680px">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="ClientId" class="form-label"></label>
                    <select asp-for="ClientId" asp-items="ViewBag.Clients" id="clientSelect" class="form-select">
                        <option value="">— select client —</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="DeviceId" class="form-label"></label>
                    <select asp-for="DeviceId" asp-items="ViewBag.Devices" id="deviceSelect" class="form-select">
                        <option value="">— select device —</option>
                    </select>
                    <span asp-validation-for="DeviceId" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
                </div>
                <div class="col-sm-6">
                    <label asp-for="AssignedEngineerId" class="form-label"></label>
                    <select asp-for="AssignedEngineerId" asp-items="ViewBag.Engineers" class="form-select">
                        <option value="">— unassigned —</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="ProblemDescription" class="form-label"></label>
                    <textarea asp-for="ProblemDescription" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="ProblemDescription" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="InternalNotes" class="form-label"></label>
                    <textarea asp-for="InternalNotes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-sm-6">
                    <label asp-for="EstimatedTimeOut" class="form-label"></label>
                    <input asp-for="EstimatedTimeOut" type="date" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ActualTimeOut" class="form-label"></label>
                    <input asp-for="ActualTimeOut" type="date" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="EstimatedPrice" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="EstimatedPrice" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="EstimatedPrice" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('clientSelect').addEventListener('change', function () {
            const clientId = this.value;
            const deviceSelect = document.getElementById('deviceSelect');
            const currentDevice = @Model.DeviceId;
            deviceSelect.innerHTML = '<option value="">— select device —</option>';
            if (!clientId) return;
            fetch(`/Tickets/GetDevicesByClient?clientId=${clientId}`)
                .then(r => r.json())
                .then(devices => {
                    devices.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value = d.id;
                        opt.text = d.name;
                        if (d.id === currentDevice) opt.selected = true;
                        deviceSelect.appendChild(opt);
                    });
                });
        });
    </script>
}
