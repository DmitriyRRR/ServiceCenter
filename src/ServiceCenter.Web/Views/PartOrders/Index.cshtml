@model IEnumerable<ServiceCenter.Domain.Entities.PartOrder>
@using ServiceCenter.Domain.Enums
@{
    ViewData["Title"] = "Part Orders";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as PartOrderStatus?;
}

@functions {
    static string StatusBadge(PartOrderStatus s) => s switch
    {
        PartOrderStatus.Pending   => "secondary",
        PartOrderStatus.Ordered   => "primary",
        PartOrderStatus.Received  => "success",
        PartOrderStatus.Cancelled => "danger",
        _                         => "secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Part Orders</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-cart-plus me-1"></i>New Order
        </a>
    }
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" value="@search" class="form-control form-control-sm"
                   placeholder="Search by part, SKU, supplier…" style="max-width:280px" />
            <select name="status" class="form-select form-select-sm" style="max-width:160px">
                <option value="">All statuses</option>
                @foreach (var s in Enum.GetValues<PartOrderStatus>())
                {
                    <option value="@((int)s)" selected="@(status == s)">@s</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-search me-1"></i>Filter
            </button>
            @if (!string.IsNullOrWhiteSpace(search) || status.HasValue)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-muted text-center py-5">
            <i class="bi bi-cart fs-1 d-block mb-2"></i>
            <span>No orders found.</span>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Part</th>
                        <th class="text-center">Qty</th>
                        <th>Status</th>
                        <th>Supplier</th>
                        <th>Ordered</th>
                        <th>Expected</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="text-muted small">#@o.Id</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.Id" class="fw-semibold text-decoration-none">
                                    @o.Part.Name
                                </a>
                                @if (o.Part.SKU != null)
                                {
                                    <span class="text-muted small ms-1">@o.Part.SKU</span>
                                }
                            </td>
                            <td class="text-center">@o.Quantity</td>
                            <td><span class="badge bg-@StatusBadge(o.Status)">@o.Status</span></td>
                            <td>@(o.SupplierName ?? "—")</td>
                            <td>@o.OrderedAt.ToString("dd MMM yyyy")</td>
                            <td>@(o.ExpectedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@o.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@o.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">@Model.Count() order(s)</div>
    </div>
}
