@model ServiceCenter.Domain.Entities.PartOrder
@using ServiceCenter.Domain.Enums
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    ViewData["Breadcrumb"] = $"<a href='/PartOrders' class='text-decoration-none'>Orders</a> / #{Model.Id}";

    string StatusBadge(PartOrderStatus s) => s switch
    {
        PartOrderStatus.Pending   => "secondary",
        PartOrderStatus.Ordered   => "primary",
        PartOrderStatus.Received  => "success",
        PartOrderStatus.Cancelled => "danger",
        _                         => "secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-semibold mb-0">Order #@Model.Id</h4>
        <span class="badge bg-@StatusBadge(Model.Status) mt-1">@Model.Status</span>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("ServiceManager"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>
    }
    else
    {
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    }
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="bi bi-cart me-2"></i>Order Details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Part</dt>
                    <dd class="col-sm-7">
                        <a asp-controller="Parts" asp-action="Details" asp-route-id="@Model.PartId"
                           class="text-decoration-none fw-semibold">@Model.Part.Name</a>
                        @if (Model.Part.SKU != null)
                        {
                            <span class="text-muted small ms-1">(@Model.Part.SKU)</span>
                        }
                    </dd>
                    <dt class="col-sm-5 text-muted">Quantity</dt>
                    <dd class="col-sm-7">@Model.Quantity</dd>
                    <dt class="col-sm-5 text-muted">Supplier</dt>
                    <dd class="col-sm-7">@(Model.SupplierName ?? "—")</dd>
                    <dt class="col-sm-5 text-muted">Ordered</dt>
                    <dd class="col-sm-7">@Model.OrderedAt.ToString("dd MMM yyyy HH:mm")</dd>
                    <dt class="col-sm-5 text-muted">Expected</dt>
                    <dd class="col-sm-7">@(Model.ExpectedAt?.ToString("dd MMM yyyy") ?? "—")</dd>
                    <dt class="col-sm-5 text-muted">Received</dt>
                    <dd class="col-sm-7">@(Model.ReceivedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>
                    <dt class="col-sm-5 text-muted">Created by</dt>
                    <dd class="col-sm-7">@(Model.CreatedBy?.UserName ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-journal-text me-2"></i>Notes</div>
                <div class="card-body">
                    <p class="mb-0" style="white-space:pre-wrap">@Model.Notes</p>
                </div>
            </div>
        </div>
    }
</div>
