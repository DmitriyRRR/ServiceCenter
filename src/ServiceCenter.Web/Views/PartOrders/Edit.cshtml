@model ServiceCenter.Web.Models.PartOrderFormViewModel
@using ServiceCenter.Domain.Enums
@{
    ViewData["Title"] = $"Edit Order #{Model.Id}";
    ViewData["Breadcrumb"] = "<a href='/PartOrders' class='text-decoration-none'>Orders</a> / Edit";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-semibold mb-0">Edit Order #@Model.Id</h4>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

@if (Model.Status != PartOrderStatus.Received)
{
    <div class="alert alert-info small">
        <i class="bi bi-info-circle me-1"></i>
        Setting status to <strong>Received</strong> will automatically add the ordered quantity to the part's stock.
    </div>
}

<div class="card" style="max-width:580px">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-sm-8">
                    <label asp-for="PartId" class="form-label"></label>
                    <select asp-for="PartId" asp-items="ViewBag.Parts" class="form-select">
                        <option value="">— select part —</option>
                    </select>
                    <span asp-validation-for="PartId" class="text-danger small"></span>
                </div>
                <div class="col-sm-4">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
                </div>
                <div class="col-sm-6">
                    <label asp-for="ExpectedAt" class="form-label"></label>
                    <input asp-for="ExpectedAt" type="date" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="ReceivedAt" class="form-label"></label>
                    <input asp-for="ReceivedAt" type="date" class="form-control" />
                    <div class="form-text">Leave blank to auto-fill when marking as Received.</div>
                </div>
                <div class="col-sm-6">
                    <label asp-for="SupplierName" class="form-label"></label>
                    <input asp-for="SupplierName" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
